# ─────────────────────────────────────────────────────────────
# Creative Scanner Pro — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# SQLite (default, local dev only — data lost on Render restart):
DATABASE_URL=sqlite:///./scanner.db
CRM_DATABASE_URL=sqlite:///./ctr_app.db

# PostgreSQL (Railway / production — persistent):
# DATABASE_URL=postgresql://user:password@host:5432/scanner_db
# CRM_DATABASE_URL=postgresql://user:password@host:5432/ctr_db

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to allow all (dev).
# Example: https://your-app.netlify.app,https://admin.example.com
ALLOWED_ORIGINS=

# ── Security ──────────────────────────────────────────────────
# Protects all API endpoints. Leave blank to disable (dev only).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── AI Vision (optional) ──────────────────────────────────────
# Claude Vision-powered ad slot detection.
# Leave blank to use DOM scanner only (no API cost).
ANTHROPIC_API_KEY=

# ── Paths (override for Render persistent disk) ───────────────
# SCREENSHOTS_DIR=/app/data/screenshots
# INPUT_IMAGES_DIR=/app/data/input_images
# PROCESSED_OUTPUTS_DIR=/app/data/processed_outputs

# ── App ───────────────────────────────────────────────────────
APP_ENV=development        # development | production
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

# ── Browser engine ────────────────────────────────────────────
HEADLESS=true
ENGINE_CONCURRENCY=5       # Lower for cloud: 3 on free tier, 8 on starter
ENGINE_NAV_TIMEOUT_MS=45000
